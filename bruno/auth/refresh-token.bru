meta {
  name: Refresh Token
  type: http
  seq: 4
}

post {
  url: {{base_url}}/api/users/token/refresh
  body: json
}

body:json {
  {
    "refresh": "{{refresh_token}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("access_token", res.body.data.access);
    bru.setVar("refresh_token", res.body.data.refresh);
  }
}
