meta {
  name: Login
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/users/login
  body: json
}

body:json {
  {
    "email": "test@example.com",
    "password": "password123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("access_token", res.body.data.access);
    bru.setVar("refresh_token", res.body.data.refresh);
  }
}
